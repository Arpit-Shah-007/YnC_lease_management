# Supabase — Project Settings -> API
NEXT_PUBLIC_SUPABASE_URL=your-supabase-project-url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Groq — https://console.groq.com/keys (used for AI lease data extraction)
GROQ_API_KEY=your-groq-api-key

# Auth — session signing secret (generate a long random string)
AUTH_SECRET=your-random-session-signing-secret

# Auth — demo/admin login credentials
AUTH_ADMIN_EMAIL=admin@example.com
AUTH_ADMIN_PASSWORD=change-me
AUTH_USER_EMAIL=user@example.com
AUTH_USER_PASSWORD=change-me
